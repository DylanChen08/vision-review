# 通过 ai.config.ts 里的集中预设选择模型：openai、moonshot、doubao、qwen
AI_MODEL_PRESET=openai

# 按所选 preset 填对应 Key。不要混用不同厂商的 Key。
OPENAI_API_KEY=
# MOONSHOT_API_KEY=
# DOUBAO_API_KEY=
# QWEN_API_KEY=

# 可选覆盖项。通常不需要设置，只有临时改模型或接入自定义兼容端时使用。
# AI_MODEL=
# AI_BASE_URL=
# AI_API_KEY=

# DeepSeek 官方 api.deepseek.com 不支持本应用所需的图片消息，请勿用于视觉走查。

# Optional local development fallback. Keep false in production.
AI_ENABLE_MOCK=false
