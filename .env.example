AI_PROVIDER=openai
AI_API_KEY=
AI_MODEL=gpt-4o
AI_BASE_URL=https://api.openai.com/v1

# Kimi 视觉示例（需在 https://platform.moonshot.ai 申请 Key）：
# AI_PROVIDER=moonshot
# MOONSHOT_API_KEY=
# AI_MODEL=kimi-k2.5
# AI_BASE_URL=https://api.moonshot.cn/v1

# DeepSeek 官方 api.deepseek.com 不支持本应用所需的图片消息，请勿用于视觉走查。

# Optional local development fallback. Keep false in production.
AI_ENABLE_MOCK=false
